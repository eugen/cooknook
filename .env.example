# Copy this to .env.local and fill in your values
# Never commit .env.local to git

# Supabase — get these from your project settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic API key — used client-side for AI features
# Note: for a private family app this is fine.
# If you ever make this public, move AI calls to a Supabase Edge Function.
VITE_ANTHROPIC_API_KEY=sk-ant-...
